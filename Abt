    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'Poppins', sans-serif; background:#f7f9f6; color:#333; overflow-x: hidden; }

        /* --- NAVIGATION --- */
        header { position: sticky; top:0; z-index:1000; background:white; padding:1rem 2rem; display:flex; justify-content:space-between; align-items:center; box-shadow:0 2px 15px rgba(0,0,0,0.05); }
        .logo { display:flex; align-items:center; font-weight:800; font-size:1.4rem; color:#1b5e20; text-decoration:none; gap:10px; }
        .logo-icon { width: 40px; height: 40px; background: #e8f5e9; border-radius: 10px; display: flex; align-items: center; justify-content: center; border: 2px solid #2e7d32; color: #2e7d32; }
        
        nav ul { list-style:none; display:flex; gap:2rem; align-items: center; }
        nav ul li a { text-decoration:none; color:#555; font-weight:600; transition: 0.3s; font-size: 0.95rem; }
        nav ul li a:hover, nav ul li a.active { color:#2e7d32; }

        /* Mobile Sidebar Logo Styling */
        .mobile-nav-header { display: none; width: 100%; padding: 2rem 1rem; border-bottom: 1px solid #eee; margin-bottom: 1.5rem; flex-direction: column; align-items: center; text-align: center; }

        /* --- HAMBURGER MENU --- */
        .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; z-index: 1100; position: relative; }
        .hamburger span { width: 28px; height: 3px; background: #1b5e20; border-radius: 2px; transition: 0.3s; }

        @media (max-width: 768px) {
            .hamburger { display: flex; }
            .mobile-nav-header { display: flex; }
            nav ul { 
                position: fixed; top: 0; right: -100%; width: 280px; height: 100vh; 
                background: white; flex-direction: column; justify-content: flex-start; 
                box-shadow: -10px 0 30px rgba(0,0,0,0.1); transition: 0.4s ease; 
            }
            nav ul.show { right: 0; }
            nav ul li { width: 100%; text-align: center; margin-bottom: 10px; }
        }

        /* --- ABOUT CONTENT --- */
        .about-hero { background: linear-gradient(rgba(27, 94, 32, 0.85), rgba(27, 94, 32, 0.85)), url('https://images.unsplash.com/photo-1523348837708-15d4a09cfac2?auto=format&fit=crop&w=1200'); background-size: cover; background-position: center; color: white; padding: 6rem 2rem; text-align: center; }
        .about-hero h1 { font-size: 3rem; margin-bottom: 10px; }

        .content-section { max-width: 1100px; margin: 4rem auto; padding: 0 2rem; }
        .mission-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: center; }
        .mission-grid img { width: 100%; border-radius: 20px; box-shadow: 0 15px 30px rgba(0,0,0,0.1); }
        
        @media (max-width: 768px) { .mission-grid { grid-template-columns: 1fr; text-align: center; } }

        /* --- FOOTER --- */
        footer { background:#1b5e20; color:white; padding:4rem 2rem 2rem; margin-top: 5rem; }
        .footer-container { max-width:1100px; margin:auto; display:grid; grid-template-columns:repeat(auto-fit,minmax(250px,1fr)); gap:2rem; }
        .footer-link { color:#e8f5e9; text-decoration:none; display:flex; align-items:center; gap:8px; margin-bottom: 12px; transition: 0.3s; }
        .footer-link:hover { color: white; padding-left: 5px; }
        .social-icons { display: flex; gap: 15px; margin-top: 15px; }
        .social-circle { width: 38px; height: 38px; background: rgba(255,255,255,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; transition: 0.3s; }
        .social-circle:hover { background: #4caf50; transform: translateY(-3px); }

        /* --- ORIGINAL WHATSAPP BUTTON (Authentic Look) --- */
        .whatsapp-btn { 
            position:fixed; bottom:30px; right:30px; 
            background:#25d366; color:white; 
            padding:12px 22px; border-radius:50px; 
            font-weight:700; text-decoration:none; 
            box-shadow:0 4px 10px rgba(0,0,0,0.15); 
            z-index: 1001; display:flex; align-items:center; gap:10px; 
            transition: 0.3s;
            /* The "Original" look: semi-transparent white border line */
            border: 1px solid rgba(255, 255, 255, 0.4);
        }
        .whatsapp-btn:hover { transform: translateY(-3px); box-shadow: 0 6px 15px rgba(0,0,0,0.2); }
        .whatsapp-btn i { width: 20px; height: 20px; }
    </style>
</head>
