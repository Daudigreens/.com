<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us | Daudi Greens Foundation</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'Poppins', sans-serif; background:#f7f9f6; color:#333; overflow-x: hidden; }

        /* --- NAVIGATION --- */
        header { position: sticky; top:0; z-index:1000; background:white; padding:1rem 2rem; display:flex; justify-content:space-between; align-items:center; box-shadow:0 2px 15px rgba(0,0,0,0.05); }
        .logo { display:flex; align-items:center; font-weight:800; font-size:1.4rem; color:#1b5e20; text-decoration:none; gap:10px; }
        .logo-icon { width: 40px; height: 40px; background: #e8f5e9; border-radius: 10px; display: flex; align-items: center; justify-content: center; border: 2px solid #2e7d32; color: #2e7d32; }
        
        nav ul { list-style:none; display:flex; gap:2rem; align-items: center; }
        nav ul li a { text-decoration:none; color:#555; font-weight:600; transition: 0.3s; font-size: 0.95rem; }
        nav ul li a:hover, nav ul li a.active { color:#2e7d32; }

        /* --- MOBILE MENU LOGO SECTION --- */
        .mobile-menu-branding {
            display: none; /* Hidden on desktop */
            width: 100%;
            padding: 3rem 1rem 2rem;
            flex-direction: column;
            align-items: center;
            border-bottom: 1px solid #f0f0f0;
            margin-bottom: 1.5rem;
        }

        .hamburger { display: flex; flex-direction: column; gap: 5px; cursor: pointer; z-index: 1100; display: none; }
        .hamburger span { width: 28px; height: 3px; background: #1b5e20; border-radius: 2px; transition: 0.3s; }

        @media (max-width: 768px) {
            .hamburger { display: flex; }
            .mobile-menu-branding { display: flex; }
            nav ul { 
                position: fixed; top: 0; right: -100%; width: 80%; height: 100vh; 
                background: white; flex-direction: column; justify-content: flex-start; 
                align-items: center; box-shadow: -10px 0 30px rgba(0,0,0,0.1); transition: 0.4s ease; 
                overflow-y: auto;
            }
            nav ul.show { right: 0; }
            nav ul li { margin: 0.8rem 0; width: 100%; text-align: center; }
        }

        /* --- ABOUT CONTENT --- */
        .about-hero { background: linear-gradient(rgba(27, 94, 32, 0.85), rgba(27, 94, 32, 0.85)), url('https://images.unsplash.com/photo-1523348837708-15d4a09cfac2?auto=format&fit=crop&w=1200'); background-size: cover; background-position: center; color: white; padding: 6rem 2rem; text-align: center; }
        .about-hero h1 { font-size: 2.5rem; margin-bottom: 10px; }

        .content-section { max-width: 1100px; margin: 4rem auto; padding: 0 2rem; }
        .mission-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: center; }
        .mission-grid img { width: 100%; border-radius: 20px; box-shadow: 0 15px 30px rgba(0,0,0,0.1); }
        
        @media (max-width: 768px) { .mission-grid { grid-template-columns: 1fr; text-align: center; } }

        /* --- FOOTER --- */
        footer { background:#1b5e20; color:white; padding:4rem 2rem 2rem; margin-top: 5rem; }
        .footer-container { max-width:1100px; margin:auto; display:grid; grid-template-columns:repeat(auto-fit,minmax(250px,1fr)); gap:2rem; }
        .footer-link { color:#e8f5e9; text-decoration:none; display:flex; align-items:center; gap:8px; margin-bottom: 12px; transition: 0.3s; font-size: 0.9rem; }
        .social-icons { display: flex; gap: 15px; margin-top: 15px; }
        .social-circle { width: 38px; height: 38px; background: rgba(255,255,255,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; }

        /* --- WHATSAPP BUTTON (HOME STYLE) --- */
        .whatsapp-btn { 
            position:fixed; bottom:30px; right:30px; 
            background:#25d366; color:white; 
            padding:12px 25px; border-radius:50px; 
            font-weight:700; text-decoration:none; 
            box-shadow:0 8px 20px rgba(37,211,102,0.4); 
            z-index: 1001; display:flex; align-items:center; gap:10px; 
            transition: 0.3s; 
        }
        .whatsapp-btn:hover { transform: scale(1.05); background: #20ba5a; }
    </style>
</head>
<body>

<header>
  <a href="index.html" class="logo">
    <div class="logo-icon"><i data-lucide="leaf"></i></div>
    <span>DAUDI <span style="color:#4caf50;">GREENS</span></span>
  </a>

  <nav>
    <ul id="nav-links">
      <li class="mobile-menu-branding">
        <div class="logo" style="font-size: 1.6rem; flex-direction: column; gap: 12px;">
            <div class="logo-icon" style="width: 55px; height: 55px;"><i data-lucide="leaf" size="30"></i></div>
            <span>DAUDI <span style="color:#4caf50;">GREENS</span></span>
        </div>
      </li>

      <li><a href="index.html">Home</a></li>
      <li><a href="about.html" class="active">About</a></li>
      <li><a href="services.html">Services</a></li>
      <li><a href="gallery.html">Gallery</a></li>
      <li><a href="contact.html">Contact</a></li>
    </ul>
  </nav>

  <div class="hamburger" id="hamburger">
    <span></span>
    <span></span>
    <span></span>
  </div>
</header>

<section class="about-hero">
    <h1>About Our Foundation</h1>
    <p>Empowering Kenya through green innovation.</p>
</section>

<section class="content-section">
    <div class="mission-grid">
        <div>
            <h2 style="color: #1b5e20; margin-bottom: 1.5rem; font-size: 2rem;">Our Mission</h2>
            <p style="line-height: 1.8; color: #555;">Daudi Greens Foundation (DGF) is a community-focused organization dedicated to teaching sustainable agricultural practices and protecting our local environment.</p>
        </div>
        <img src="https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?auto=format&fit=crop&w=800" alt="Sustainable Farming">
    </div>
</section>

<footer>
  <div class="footer-container">
    <div>
      <h4>DGF Africa</h4>
      <p style="font-size:0.9rem; opacity:0.8; margin-top:10px;">Leading the way in green initiatives across the region.</p>
      <div class="social-icons">
        <a href="#" class="social-circle"><i data-lucide="facebook" size="18"></i></a>
        <a href="#" class="social-circle"><i data-lucide="instagram" size="18"></i></a>
      </div>
    </div>
    <div>
      <h4>Quick Links</h4>
      <a href="index.html" class="footer-link">Home</a>
      <a href="services.html" class="footer-link">Our Services</a>
    </div>
    <div>
      <h4>Contact Us</h4>
      <div class="footer-link">Nairobi, Kenya</div>
      <div class="footer-link">info@daudigreens.org</div>
    </div>
  </div>
</footer>

<a href="https://wa.me/254700000000?text=Hello%20Daudi%20Greens%21%20I'm%20reaching%20out%20to%20learn%20more%20about%20your%20foundation's%20work." 
   class="whatsapp-btn" 
   target="_blank">
    <i data-lucide="message-circle"></i> WhatsApp
</a>

<script>
    lucide.createIcons();

    const hamburger = document.getElementById('hamburger');
    const navLinks = document.getElementById('nav-links');
    
    hamburger.addEventListener('click', () => {
        navLinks.classList.toggle('show');
        const spans = hamburger.querySelectorAll('span');
        if(navLinks.classList.contains('show')) {
            spans[0].style.transform = 'rotate(45deg) translate(5px, 6px)';
            spans[1].style.opacity = '0';
            spans[2].style.transform = 'rotate(-45deg) translate(5px, -6px)';
        } else {
            spans[0].style.transform = 'none';
            spans[1].style.opacity = '1';
            spans[2].style.transform = 'none';
        }
    });

    // Close menu when clicking links
    document.querySelectorAll('#nav-links a').forEach(link => {
        link.addEventListener('click', () => navLinks.classList.remove('show'));
    });
</script>
</body>
</html>