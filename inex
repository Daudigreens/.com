<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daudi Greens Foundation (DGF)</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        :root {
            --primary: #1b5e20;
            --secondary: #4caf50;
            --light-bg: #f7f9f6;
            --text-dark: #333;
            --soft-green: #f0f7f0;
        }

        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'Poppins', sans-serif; background: var(--light-bg); color: var(--text-dark); overflow-x: hidden; }

        /* --- Navbar --- */
        header { position: sticky; top:0; z-index:1000; background:white; padding:1rem 2rem; display:flex; justify-content:space-between; align-items:center; box-shadow:0 2px 15px rgba(0,0,0,0.05); }
        
        .logo { display:flex; align-items:center; font-weight:800; font-size:1.4rem; color: var(--primary); text-decoration:none; gap:10px; }
        .logo-icon { width: 40px; height: 40px; background: #e8f5e9; border-radius: 10px; display: flex; align-items: center; justify-content: center; border: 2px solid var(--primary); color: var(--primary); }
        
        nav ul { list-style:none; display:flex; gap:2rem; align-items: center; }
        nav ul li a { text-decoration:none; color:#555; font-weight:600; transition: 0.3s; font-size: 0.95rem; }
        nav ul li a:hover, nav ul li a.active { color: var(--primary); }

        /* Mobile Menu Branding */
        .mobile-menu-branding {
            display: none; width: 100%; padding: 3rem 1rem 2rem;
            flex-direction: column; align-items: center;
            border-bottom: 1px solid #f0f0f0; margin-bottom: 1.5rem;
        }

        .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; z-index: 1100; }
        .hamburger span { width: 28px; height: 3px; background: var(--primary); border-radius: 2px; transition: 0.3s; }

        @media (max-width: 768px) {
            .hamburger { display: flex; }
            .mobile-menu-branding { display: flex; }
            nav ul { 
                position: fixed; top: 0; right: -100%; width: 80%; height: 100vh; 
                background: white; flex-direction: column; justify-content: flex-start; 
                align-items: center; box-shadow: -10px 0 30px rgba(0,0,0,0.1); transition: 0.4s ease; 
            }
            nav ul.show { right: 0; }
            nav ul li { margin: 0.8rem 0; }
        }

        /* --- Hero --- */
        .hero { 
            display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; 
            padding:10rem 2rem; 
            background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('https://images.unsplash.com/photo-1466692476868-aef1dfb1e735?auto=format&fit=crop&w=1600&q=80'); 
            background-size: cover; background-position: center; color:white; 
        }
        .hero h1 { font-size:clamp(2rem, 5vw, 3.5rem); margin-bottom:1rem; text-shadow: 2px 2px 10px rgba(0,0,0,0.5); font-weight: 800; }
        .hero p { font-size:1.1rem; max-width:700px; margin-bottom:2.5rem; text-shadow: 1px 1px 5px rgba(0,0,0,0.5); line-height: 1.6; }
        
        .hero-btns { display: flex; gap: 15px; flex-wrap: wrap; justify-content: center; }
        .btn { padding:0.9rem 2.2rem; border-radius:50px; font-weight:700; text-decoration:none; transition: 0.3s; border: 2px solid transparent; }
        .btn-primary { background: var(--primary); color: white; }
        .btn-primary:hover { background: var(--secondary); transform: translateY(-3px); }
        .btn-outline { background: rgba(255,255,255,0.1); color: white; border-color: white; backdrop-filter: blur(5px); }
        .btn-outline:hover { background: white; color: var(--primary); }

        /* --- Smarter Stats Bar --- */
        .stats-bar { 
            background: #ffffff; 
            border-bottom: 1px solid #eee;
            padding: 5rem 2rem; 
        }
        .stats-container {
            max-width: 1100px;
            margin: auto;
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); 
            gap: 2rem;
        }
        .stat-item {
            text-align: center;
            padding: 2.5rem 1rem;
            border-radius: 20px;
            background: var(--soft-green); 
            transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .stat-item:hover {
            background: #e8f5e9;
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.05);
        }
        .stat-item h2 { 
            font-size: 3.2rem; 
            margin-bottom: 5px; 
            color: var(--primary); 
            font-weight: 800;
        }
        .stat-item p { 
            font-weight: 700; 
            color: var(--secondary); 
            text-transform: uppercase; 
            letter-spacing: 2px;
            font-size: 0.85rem;
        }

        /* --- Sections Shared --- */
        section { padding: 5rem 2rem; }
        .section-title { text-align:center; margin-bottom:3rem; color: var(--primary); font-size: 2.2rem; }
        .container { max-width: 1100px; margin: auto; }

        /* --- Content Blocks --- */
        .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; }
        .card { background: white; padding: 2.5rem; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); transition: 0.3s; border: 1px solid #eee; }
        .card:hover { transform: translateY(-10px); border-color: var(--secondary); }
        .card i { color: var(--secondary); margin-bottom: 1.5rem; display: block; }
        .card h3 { color: var(--primary); margin-bottom: 1rem; }
        .card p { color: #666; line-height: 1.6; }

        /* --- Carousel --- */
        .carousel-container { padding: 4rem 1rem; background: #fff; }
        .swiper { width: 100%; height: 500px; border-radius: 25px; }
        .swiper-slide { position: relative; }
        .swiper-slide img { width: 100%; height: 100%; object-fit: cover; }
        .slide-content { position: absolute; bottom: 0; left: 0; right: 0; padding: 3rem 2rem; background: linear-gradient(transparent, rgba(0,0,0,0.9)); color: white; }

        /* --- Footer --- */
        footer { background: var(--primary); color:white; padding:4rem 2rem 2rem; }
        .footer-container { max-width:1100px; margin:auto; display:grid; grid-template-columns:repeat(auto-fit,minmax(250px,1fr)); gap:3rem; }
        .footer-container h4 { margin-bottom: 1.5rem; font-size: 1.1rem; }
        .footer-link { color:#e8f5e9; text-decoration:none; display:flex; align-items:center; gap:10px; margin-bottom: 12px; transition: 0.3s; font-size: 0.9rem; }
        .footer-link:hover { color: white; padding-left: 5px; }
        .social-icons { display: flex; gap: 12px; margin-top: 20px; }
        .social-circle { width: 40px; height: 40px; background: rgba(255,255,255,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; transition: 0.3s; }
        .social-circle:hover { background: var(--secondary); transform: translateY(-3px); }

        /* WhatsApp */
        .whatsapp-btn { 
            position:fixed; bottom:30px; right:30px; 
            background:#25d366; color:white; 
            padding:12px 25px; border-radius:50px; 
            font-weight:700; text-decoration:none; 
            box-shadow:0 8px 20px rgba(37,211,102,0.4); 
            z-index: 1001; display:flex; align-items:center; gap:10px; 
            transition: 0.3s; 
        }
        .whatsapp-btn:hover { transform: scale(1.05); background: #20ba5a; }
    </style>
</head>
